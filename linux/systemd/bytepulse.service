[Unit]
Description=BytePulse WiFi Data Tracker
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=moses-amwoma
WorkingDirectory=/home/moses-amwoma/Documents/projects/BytePulse
ExecStart=/home/moses-amwoma/Documents/projects/BytePulse/linux/venv/bin/python3 /home/moses-amwoma/Documents/projects/BytePulse/linux/src/tracker.py
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal
Environment="PYTHONPATH=/home/moses-amwoma/Documents/projects/BytePulse"

[Install]
WantedBy=multi-user.target